# Database
DATABASE_URL=postgresql://wpmhs:Clay125524@localhost:5434/devsroom_conversionflow_db

# Redis (optional in dev - in-memory fallback when not set)
REDIS_URL=redis://localhost:6381

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Seed (used by pnpm db:seed)
ADMIN_EMAIL=admin@devsroom.com
ADMIN_PASSWORD=change-me-in-production

# Optional: Admin Setup Token (for /admin/setup route protection)
# ADMIN_SETUP_TOKEN=

# Resend (for auth emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email From
EMAIL_FROM=noreply@conversionflow.com

# SSL Commerce (Sandbox for development)
SSL_COMMERZ_STORE_ID=your_store_id
SSL_COMMERZ_STORE_PASSWORD=your_store_password
SSL_COMMERZ_SANDBOX=true

# Central Licensing API
CENTRAL_API_URL=https://license.devsroom.com
CENTRAL_API_KEY=your_central_api_key
